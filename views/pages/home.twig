{% from 'components/button.twig' import btn %}
{% from 'components/input.twig' import input %}
{% extends 'layouts/base.twig' %}

{% block content %}
  <div
    class="bg-primary dark:bg-secondary dark:text-secondary-foreground text-primary-foreground hero mb-8 rounded-xl p-8 pt-60 shadow-xl"
  >
    <div class="prose-xl max-w-3xl">
      <h1>{{ post.title }}</h1>
      <div>
        {{ post.content }}
      </div>
    </div>
  </div>

  <form
    class="content relative grid grid-cols-[1fr_4fr] items-start gap-8 px-4"
    id="posts-form"
    method="get"
    action="{{ site.home_url }}"
    hx-get="{{ htmxWP.ajaxUrl }}"
    hx-target="#posts"
    hx-swap="outerHTML"
    hx-indicator="#posts-indicator"
    hx-trigger="keyup changed delay:300ms from:#search-input"
    :hx-push-url="`{{ posts_url }}` + (s ? `?s=${encodeURIComponent(s)}` : '')"
    onsubmit="return false;"
    x-data="{
      s: '{{ params.s }}'
    }"
  >
    <aside
      class="border-border bg-card sticky top-36 rounded-md border p-4 shadow-sm"
    >
      {# Required params for admin-ajax #}
      <input type="hidden" name="action" value="htmx_posts" />
      <input type="hidden" name="nonce" value="{{ htmxWP.nonce }}" />

      {# Search input #}
      {{
        input({
          label: 'Search',
          name: 's',
          id: 'search-input',
          placeholder: 'Search posts...',
          suffix: lucide('search'),
          block: true,
          type: 'text',
          value: params.s,
          attributes: {
            'x-model': 's',
            'hx-trigger': 'keyup changed delay:300ms'
          }
        })
      }}
    </aside>

    <div class="relative">
      <div
        id="posts-indicator"
        class="bg-background/50 absolute top-0 left-0 hidden h-full w-full"
      ></div>

      {% include 'partials/post-loop.twig' %}
    </div>
  </form>
{% endblock %}
