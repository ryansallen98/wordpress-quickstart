{# --- Pagination (drop below the grid) --- #}
{% import _self as macros %}

{% set current =
  (pagination.current ?? posts.pagination.current ?? current_page ?? 1)|default(
    1
  )
%}
{% set total =
  (pagination.total ?? posts.pagination.total ?? total_pages ?? 1)|default(1)
%}

{% if total > 1 %}
  <nav class="mt-10 flex items-center justify-center" aria-label="Pagination">
    <ul class="inline-flex items-center gap-1">
      {# Prev #}
      {% if current > 1 %}
        <li>
          <a
            href="{{ macros.page_url(current - 1) }}"
            rel="prev"
            class="hover:bg-accent hover:text-accent-foreground inline-flex items-center rounded-md border px-3 py-2 text-sm"
          >
            ‹ Prev
          </a>
        </li>
      {% else %}
        <li>
          <span
            class="text-muted-foreground inline-flex items-center rounded-md border px-3 py-2 text-sm opacity-60"
            aria-disabled="true"
          >
            ‹ Prev
          </span>
        </li>
      {% endif %}

      {# Page numbers with smart ellipses #}
      {% set last_shown = 0 %}
      {% for i in 1..total %}
        {% set show = i == 1
          or i == total
          or (i >= current - 1 and i <= current + 1)
          or total <= 7
        %}

        {% if show %}
          {% if i > last_shown + 1 %}
            <li>
              <span class="text-muted-foreground px-2 text-sm select-none">
                …
              </span>
            </li>
          {% endif %}

          {% if i == current %}
            <li>
              <span
                aria-current="page"
                class="bg-primary text-primary-foreground inline-flex items-center rounded-md border px-3 py-2 text-sm"
              >
                {{ i }}
              </span>
            </li>
          {% else %}
            <li>
              <a
                href="{{ macros.page_url(i) }}"
                class="hover:bg-accent hover:text-accent-foreground inline-flex items-center rounded-md border px-3 py-2 text-sm"
              >
                {{ i }}
              </a>
            </li>
          {% endif %}

          {% set last_shown = i %}
        {% endif %}
      {% endfor %}

      {# Next #}
      {% if current < total %}
        <li>
          <a
            href="{{ macros.page_url(current + 1) }}"
            rel="next"
            class="hover:bg-accent hover:text-accent-foreground inline-flex items-center rounded-md border px-3 py-2 text-sm"
          >
            Next ›
          </a>
        </li>
      {% else %}
        <li>
          <span
            class="text-muted-foreground inline-flex items-center rounded-md border px-3 py-2 text-sm opacity-60"
            aria-disabled="true"
          >
            Next ›
          </span>
        </li>
      {% endif %}
    </ul>
  </nav>
{% endif %}

{# --- URL builder macro --- #}
{% macro page_url(i) %}
  {# Prefer WP/Timber URL for the page; fallback to query param #}
  {% if function is defined %}
    {{ function('get_pagenum_link', i) }}
  {% else %}
    {{ '?' ~ 'page=' ~ i }}
  {% endif %}
{% endmacro %}
