{% macro button(opts = {}) %}
    {# Defaults #}
    {% set label     = opts.label     | default('Button') %}
    {% set href      = opts.href      | default(null) %}
    {% set type      = opts.type      | default('button') %}
    {% set variant   = opts.variant   | default('primary') %}
    {% set size      = opts.size      | default('md') %}
    {% set block     = opts.block     | default(false) %}
    {% set disabled  = opts.disabled  | default(false) %}
    {% set loading   = opts.loading   | default(false) %}
    {% set target    = opts.target    | default(null) %}
    {% set rel       = opts.rel       | default(null) %}
    {% set prefix    = opts.prefix    | default(null) %}
    {% set suffix    = opts.suffix    | default(null) %}
    {% set classes   = opts.class     | default('') %}
    {% set attrs     = opts.attributes| default({}) %}

    {# Tailwind class maps #}
    {% set base = "cursor-pointer inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium transition-all disabled:pointer-events-none disabled:opacity-50 [&_svg]:pointer-events-none [&_svg:not([class*='size-'])]:size-4 shrink-0 [&_svg]:shrink-0 outline-none focus-visible:border-ring focus-visible:ring-ring/50 focus-visible:ring-[3px] aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive" %}

    {% set variants = {
        primary:     'bg-primary text-primary-foreground shadow-xs hover:bg-primary/90',
        destructive: 'bg-destructive text-white shadow-xs hover:bg-destructive/90 focus-visible:ring-destructive/20 dark:focus-visible:ring-destructive/40 dark:bg-destructive/60',
        outline:     'border bg-background shadow-xs hover:bg-accent hover:text-accent-foreground dark:bg-input/30 dark:border-input dark:hover:bg-input/50',
        secondary:   'bg-secondary text-secondary-foreground shadow-xs hover:bg-secondary/80',
        ghost:       'hover:bg-accent hover:text-accent-foreground dark:hover:bg-accent/50',
        link:        'text-primary underline-offset-4 hover:underline',
    } %}

    {% set sizes = {
        sm:   'h-8 rounded-md gap-1.5 px-3 has-[>svg]:px-2.5',
        md:   'h-9 px-4 py-2 has-[>svg]:px-3',
        lg:   'h-10 rounded-md px-6 has-[>svg]:px-4',
        icon: 'size-9'
    } %}

    {% set width = block ? 'w-full' : '' %}
    {% set composed = twmerge(base ~ ' ' ~ (variants[variant]|default(variants.primary)) ~ ' ' ~ (sizes[size]|default(sizes.md)) ~ ' ' ~ width ~ ' ' ~ classes)|trim %}

    {# Build attributes #}
    {% set computed_attrs = attrs|merge({
        class: composed,
        'aria-disabled': disabled ? 'true' : null,
        'data-loading': loading ? 'true' : null
    }) %}

    {% if target == '_blank' %}
        {% set computed_attrs = computed_attrs|merge({
            rel: rel ? rel : 'noopener noreferrer'
        }) %}
    {% endif %}
    
    {% set content %}
        {% if prefix %}{{ prefix|raw }}{% endif %}
        {{ label }}
        {% if suffix %}{{ suffix|raw }}{% endif %}
    {% endset %}


    {# Render anchor vs button #}
    {% if href %}
        <a href="{{ href }}"
           {% if target %}target="{{ target }}"{% endif %}
           {# loop with inner if (compat) #}
           {% for k, v in computed_attrs %}
             {% if v is not null %} {{ k }}="{{ v }}"{% endif %}
           {% endfor %}>
            {{ content|raw }}
        </a>
    {% else %}
        <button
            type="{{ type }}"
            {% if disabled %}disabled{% endif %}
            {% for k, v in computed_attrs %}
              {% if v is not null %} {{ k }}="{{ v }}"{% endif %}
            {% endfor %}>
            {{ content|raw }}
        </button>
    {% endif %}
{% endmacro %}