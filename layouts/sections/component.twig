{% from 'components/button.twig' import btn %}

<div class="flex flex-col items-center justify-center gap-4 p-16 text-center">
  <h2 class="mb-4 text-3xl font-bold">{{ text }}</h2>

  {% if button is defined and button %}
    {{
      btn({
        label: button.title,
        href: button.url,
        target: button.target,
        variant: 'primary'
      })
    }}
  {% endif %}
</div>
